# Python venv (build/validate environment)
.venv/

# MLX/Metal extension build artifacts (regenerated by setup.py build_ext).
/build/
bindings/python/build/
bindings/python/tk/_ext*.so
bindings/python/tk/*.dylib
bindings/python/tk/*.metallib
bindings/pytorch_mps/tk_torch/*.metallib

# Python caches
__pycache__/
*.pyc
.pytest_cache/

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Logs
*.log

# Secrets / local env
.env
.env.*

# Xcode
*.bak
xcuserdata/
DerivedData/

# Local reference source mirrors — local study material, not a runtime dependency
# (see bigpicture.md). Large; do not commit.
.reference/

# macOS
.DS_Store

# Compiled Metal libraries (build artifacts)
*.metallib

# Python packaging / build
*.egg-info/
.eggs/
*.egg
dist/
build/

# PyTorch MPS extension: JIT build cache lives in ~/.cache/torch_extensions (outside
# the repo); only the __pycache__ lands here and is covered above.
